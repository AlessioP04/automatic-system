    <pous>
      <pou name="impianto" pouType="program">
        <interface>
          <localVars>
            <variable name="boxWeight" address="%QW0">
              <type>
                <INT/>
              </type>
            </variable>
            <variable name="boxType" address="%QW1">
              <type>
                <INT/>
              </type>
            </variable>
            <variable name="toAddA" address="%QW2">
              <type>
                <INT/>
              </type>
            </variable>
            <variable name="toAddB" address="%QW3">
              <type>

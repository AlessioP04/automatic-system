  <types>
    <dataTypes/>
    <pous>
      <pou name="impianto" pouType="program">
        <interface>
          <localVars>
            <variable name="boxWeight" address="%MD0">
              <type>
                <REAL/>
              </type>
            </variable>
            <variable name="objectType" address="%QW0">
              <type>
                <INT/>
              </type>
            </variable>
            <variable name="toAddA" address="%QW1">
              <type>
                <INT/>
              </type>
            </variable>
            <variable name="toAddB" address="%QW2">
              <type>
                <INT/>
              </type>
            </variable>
            <variable name="toAddC" address="%QW3">
              <type>
                <INT/>
              </type>
            </variable>
            <variable name="turbineWeight" address="%MD1">
              <type>
                <REAL/>
              </type>
            </variable>
            <variable name="turbineValidity" address="%QX0.0">
              <type>
                <BOOL/>
              </type>
            </variable>
          </localVars>
        </interface>
        <body>
          <ST>
            <xhtml:p><![CDATA[IF (boxWeight >= 1.49) AND (boxWeight <= 1.51) THEN
    objectType := 1;
    toAddA := REAL_TO_INT((boxWeight-1.500)/3.0*1000.0);

ELSIF (boxWeight >= 2.48) AND (boxWeight <= 2.52) THEN
    objectType := 2;
    toAddB := REAL_TO_INT((boxWeight-2.5)/5.0*1000.0);

ELSIF (boxWeight >= 3.0) AND (boxWeight <= 3.5) THEN
    objectType := 3;
    toAddC := REAL_TO_INT((boxWeight-3.3)/50.0*1000.0);

END_IF;

IF (turbineWeight < 3.1) OR (turbineWeight > 3.4) THEN
    turbineValidity := FALSE;
ELSE   turbineValidity := TRUE;

END_IF;


]]></xhtml:p>
          </ST>
        </body>

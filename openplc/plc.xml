    <pous>
      <pou name="impianto" pouType="program">
        <interface>
          <localVars>
            <variable name="valid" address="%QX0.0">
              <type>
                <BOOL/>
              </type>
            </variable>
            <variable name="objectType" address="%QW0">
              <type>
                <INT/>
              </type>
            </variable>
            <variable name="weight" address="%MD0">
              <type>
                <REAL/>
              </type>
            </variable>
            <variable name="toAddA" address="%QW1">
              <type>
                <INT/>
              </type>
            </variable>
            <variable name="toAddB" address="%QW2">
              <type>
                <INT/>
              </type>
            </variable>
          </localVars>
        </interface>
        <body>
          <ST>
            <xhtml:p><![CDATA[IF (weight >= 1.49) AND (weight <= 1.51) THEN

    valid := TRUE;
    objectType := 1;
    toAddA := REAL_TO_INT((weight-1.500)/3.0*1000.0);

ELSIF (weight >= 2.48) AND (weight <= 2.52) THEN

    valid := TRUE;
    objectType := 2;
    toAddB := REAL_TO_INT((weight-2.5)/5.0*1000.0);

ELSIF (weight >= 3.0) AND (weight <= 3.5) THEN

    valid := (weight >= 3.1) AND (weight <= 3.4);

    IF valid THEN
        objectType := 3;
    ELSE
        objectType := 4;
    END_IF;

ELSE

    valid := FALSE;
    objectType := 4;

END_IF;


]]></xhtml:p>
          </ST>
        </body>
